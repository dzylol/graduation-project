{
  "dataset": "BBBP",
  "data_dir": "./data/BBBP",
  "train_file": "train.csv",
  "val_file": "val.csv",
  "test_file": "test.csv",
  "d_model": 256,
  "n_layers": 4,
  "task_type": "classification",
  "pooling": "mean",
  "num_labels": 1,
  "dropout": 0.1,
  "epochs": 3,
  "batch_size": 16,
  "learning_rate": 0.001,
  "weight_decay": 1e-05,
  "gradient_accumulation_steps": 1,
  "warmup_epochs": 5,
  "max_grad_norm": 1.0,
  "device": "mps",
  "seed": 42,
  "output_dir": "./checkpoints",
  "log_interval": 100,
  "eval_interval": 500,
  "save_interval": 1000,
  "max_length": 100
}